# Copy this file to .env and update with your PostgreSQL Desktop credentials
# cp env.local.example .env

# Django Core Settings
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True

# Database Configuration - PostgreSQL Desktop
# Update these values to match your PostgreSQL Desktop setup
# Format: postgresql://username:password@host:port/database_name
# For Docker containers to access PostgreSQL Desktop on Windows, use host.docker.internal
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/hms_db

# If running Django directly (not in Docker), use localhost instead:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hms_db

# Database Performance Settings (Optional)
DATABASE_CONN_MAX_AGE=600
DATABASE_CONN_HEALTH_CHECKS=True
DATABASE_TIMEOUT=10
DATABASE_SSL_MODE=prefer

# Redis Configuration (running in Docker)
REDIS_URL=redis://redis:6379/0
USE_REDIS_CACHE=True

# If running Django directly (not in Docker), use localhost:
# REDIS_URL=redis://localhost:6379/0

# Security Settings
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,192.168.2.97,192.168.233.1,192.168.64.1,172.20.112.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://0.0.0.0:8000

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost

# SMS Configuration (Optional)
SMS_API_KEY=
SMS_SENDER_ID=YourHospital
SMS_API_URL=https://sms.smsnotifygh.com/smsapi

# Site Configuration
SITE_URL=http://localhost:8000
HOSPITAL_NAME=Your Hospital Name







